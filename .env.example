DATABASE_URL="file:./dev.db"
APP_URL="http://localhost:3000"
EXPORT_OUTPUT_DIR="./exports"
USE_MOCK_DATA="true"

# API keys (optional — adapters fall back to seed data without keys)
ARTIFICIAL_ANALYSIS_API_KEY=""    # Required for live AA, GPQA, HLE, MMMLU, Arena T2V, Arena I2V

# Per-adapter live flags (only checked when USE_MOCK_DATA="false")
USE_LIVE_ARTIFICIAL_ANALYSIS="false"
USE_LIVE_ARENA_TEXT="false"
USE_LIVE_SWE_BENCH="false"
USE_LIVE_AIDER="false"
USE_LIVE_LIVEBENCH="false"
USE_LIVE_HF_OPEN_LLM="false"
USE_LIVE_ARENA_TEXT_TO_IMAGE="false"
USE_LIVE_ARENA_TEXT_TO_VIDEO="false"
USE_LIVE_ARENA_IMAGE_TO_VIDEO="false"
USE_LIVE_GPQA_DIAMOND="false"
USE_LIVE_HUMANITYS_LAST_EXAM="false"
USE_LIVE_MMMLU="false"
